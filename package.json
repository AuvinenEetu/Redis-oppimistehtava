{
  "name": "mongo-express-app",
  "version": "1.0.0",
  "description": "Node + Express app that queries a local Docker MongoDB",
  "main": "backend/app.js",
  "scripts": {
    "start": "node backend/app.js",
    "dev": "nodemon backend/app.js",
    "dev:all": "concurrently \"npm run dev\" \"npx http-server ./frontend -p 8080 -c-1\"",
    "start:all": "concurrently \"npm start\" \"npx http-server ./frontend -p 8080 -c-1\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.4.0",
    "morgan": "^1.10.0",
    "redis": "^4.6.7"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "concurrently": "^8.2.0",
    "http-server": "^14.1.1"
  }
}
